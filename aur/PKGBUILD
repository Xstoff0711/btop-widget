# Maintainer: xstoff <c.stilling83@googlemail.com>
pkgname=plasma6-btop-widget
pkgver=1.1
pkgrel=1
pkgdesc="btop resource monitor as a KDE Plasma 6 widget"
arch=('any')
url="https://github.com/Xstoff0711/btop-widget"
license=('GPL-2.0-or-later')
depends=('plasma-workspace' 'btop' 'qmltermwidget')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('ede060421c0ed54b1dfca66d759edc7712865fd65cb02afe196e7dea78d4b2ce')

package() {
    cd "$srcdir/btop-widget-$pkgver"
    local _dest="$pkgdir/usr/share/plasma/plasmoids/com.xstoff.btopwidget"
    install -Dm644 metadata.json "$_dest/metadata.json"
    install -Dm644 contents/ui/main.qml "$_dest/contents/ui/main.qml"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
